# Werk Platform - Environment Variables
# Copy to .env and customize for your environment
# NEVER commit .env files to version control

# Database
POSTGRES_DB=werk
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/werk

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# MinIO (S3-compatible artifact storage)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=werk-artifacts

# Auth (CHANGE THESE IN PRODUCTION)
SECRET_KEY=change-this-to-a-random-64-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Security
BCRYPT_ROUNDS=12
SESSION_TIMEOUT_MINUTES=480
RATE_LIMIT_PER_MINUTE=60
ALLOWED_HOSTS=*

# Vault (optional — for production secrets management)
VAULT_ADDR=
VAULT_TOKEN=
USE_VAULT=false

# LLM API Keys (optional for local dev)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Local model via Ollama — runs as a container in this stack, no external API or cost.
# After 'docker-compose up -d', pull the model once:
#   docker-compose exec ollama ollama pull llama3.2
USE_OLLAMA=true
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# Execution layer — runs model-generated code in a subprocess.
# SECURITY: only enable for local/trusted use. Off by default.
ENABLE_CODE_EXECUTION=false
WORKSPACE_ROOT=/tmp/werk_workspaces
CODE_EXECUTION_TIMEOUT=30

# Agent Config
MAX_AGENT_CONCURRENCY=5
AGENT_TIMEOUT_SECONDS=300

# Debug (disable in production)
DEBUG=true