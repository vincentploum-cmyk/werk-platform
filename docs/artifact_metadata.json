{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Werk Artifact Metadata",
  "description": "Standard metadata for any file stored in the shared workspace.",
  "type": "object",
  "properties": {
    "artifact_id": {
      "type": "string",
      "format": "uuid"
    },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["requirement", "design", "code", "test_report", "policy", "documentation"]
    },
    "format": {
      "type": "string",
      "enum": ["markdown", "json", "python", "typescript", "yaml", "pdf"]
    },
    "created_by": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "modified_at": { "type": "string", "format": "date-time" },
    "project_id": { "type": "string", "format": "uuid" },
    "stage": {
      "type": "string",
      "enum": ["Initialization", "UX_Design", "Architecture", "Development", "Testing", "Review", "Deployment"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "checksum": {
      "type": "string",
      "description": "SHA-256 hash for integrity verification."
    }
  },
  "required": ["artifact_id", "name", "type", "format", "created_by", "project_id"]
}
